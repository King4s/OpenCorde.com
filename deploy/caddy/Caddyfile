# OpenCorde reverse proxy configuration
# Domain: opencorde.com
# Public IP: 2.108.189.148 -> internal 192.168.140.140
# Caddy handles SSL termination via Let's Encrypt

opencorde.com {
    # File upload size limit (100MB)
    request_body {
        max_size 100MB
    }

    # API server
    handle /api/* {
        reverse_proxy localhost:8080
    }

    # WebSocket gateway
    handle /ws {
        # WebSocket headers for persistent connections
        reverse_proxy localhost:8080 {
            header_up Host {host}
            header_up X-Forwarded-Proto https
            header_up X-Forwarded-For {remote_host}
        }
    }

    # MinIO file storage
    handle /files/* {
        reverse_proxy localhost:9010
    }

    # Static SvelteKit client build
    # / -> prerendered landing page (index.html)
    # all other app routes -> SPA fallback (200.html)
    @root path /
    handle @root {
        root * /home/mb/opencorde/client/build
        file_server
    }

    handle {
        root * /home/mb/opencorde/client/build
        try_files {path} {path}/ /200.html
        file_server
    }

    # Note: LiveKit uses its own port (7880) and handles WebSockets directly
    # No Caddy routing needed for LiveKit
}
